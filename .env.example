# MongoDB Atlas or local connection
MONGODB_URI=mongodb://127.0.0.1:27017/back-pelotas

# JWT settings
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

NOTIFICATIONS_EMAIL_ENABLED=true

# Notifications - Gmail OAuth2 (preferred)
MAIL_USER=your-email@gmail.com
MAIL_CLIENT_ID=your-google-oauth-client-id
MAIL_CLIENT_SECRET=your-google-oauth-client-secret
MAIL_REFRESH_TOKEN=your-google-oauth-refresh-token
MAIL_FROM_NAME=Pelotas Dev
MAIL_FROM_ADDRESS=your-email@gmail.com

# Storage provider
# STORAGE_PROVIDER=local
# STORAGE_LOCAL_ROOT_PATH=uploads
# STORAGE_PUBLIC_BASE_URL=http://localhost:3000

# Firebase Storage (real provider)
# Storage provider
STORAGE_PROVIDER=firebase

# Firebase Storage (real provider)
FIREBASE_PROJECT_ID=ecpelotas-2432a
FIREBASE_STORAGE_BUCKET=ecpelotas-2432a.firebasestorage.app
GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/ecpelotas-firebase-adminsdk.json

# S3 Storage (real provider)
# Example: STORAGE_PROVIDER=s3
S3_BUCKET_NAME=your-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
# Optional (for R2/MinIO/Backblaze or custom endpoint)
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# Optional public URL base. When informed, photo URL = S3_PUBLIC_BASE_URL/<key>
# S3_PUBLIC_BASE_URL=https://cdn.your-domain.com
# Optional: true for path-style endpoints
S3_FORCE_PATH_STYLE=false